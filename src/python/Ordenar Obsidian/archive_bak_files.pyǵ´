#!/usr/bin/env python3
from pathlib import Path
import shutil

ROOT = Path("/home/elias-alvarez/GitHub/Tesis").resolve()
VAULT = ROOT / "Obsidian Vault"
ARCHIVE = ROOT / "_vault_snapshots" / "bak_files"

bak_files = sorted(VAULT.rglob("*.bak"))

if not bak_files:
    print("[INFO] No .bak files found.")
    raise SystemExit(0)

for src in bak_files:
    rel = src.relative_to(VAULT)
    dst = ARCHIVE / rel
    dst.parent.mkdir(parents=True, exist_ok=True)
    shutil.move(str(src), str(dst))
    print(f"[MOVED] {src.relative_to(ROOT)} -> {dst.relative_to(ROOT)}")

print(f"[DONE] Archived {len(bak_files)} .bak files into {ARCHIVE}")
